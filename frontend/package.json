{
  "name": "zqode-frontend",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "openapi:gen": "openapi-ts -i http://localhost:8000/openapi.json -o src/api/generated -c @hey-api/client-fetch"
  },
  "dependencies": {
    "vue": "^3.5.12",
    "vue-router": "^4.4.5",
    "pinia": "^2.2.4",
    "@vueuse/core": "^11.1.0",
    "vue-echarts": "^7.0.3",
    "echarts": "^5.5.1",
    "@hey-api/client-fetch": "^0.4.2"
  },
  "devDependencies": {
    "vite": "^5.4.10",
    "@vitejs/plugin-vue": "^5.1.4",
    "typescript": "~5.6.3",
    "vue-tsc": "^2.1.10",
    "@vue/tsconfig": "^0.5.1",
    "@hey-api/openapi-ts": "^0.55.2"
  }
}
