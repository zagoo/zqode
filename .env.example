# Production environment template for docker-compose.prod.yml.
#
#   cp .env.example .env.prod
#   # edit .env.prod, fill in the CHANGE_ME values
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build
#
# .env.prod is git-ignored (see .gitignore). Never commit real secrets.

# --- Postgres ---
POSTGRES_USER=zqode
POSTGRES_PASSWORD=CHANGE_ME_strong_random_password
POSTGRES_DB=zqode

# --- Backend / auth (required) ---
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_long_random_secret
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=14

# CSV of allowed enterprise email domains (lowercased), e.g. acme.com,partner.com
ALLOWED_EMAIL_DOMAINS=engineai.com.cn
# Bootstrap System Administrator (its domain must be in ALLOWED_EMAIL_DOMAINS)
INITIAL_ADMIN_ENTERPRISE_EMAIL=rensb@engineai.com.cn
DEFAULT_CURRENCY=USD

# console = log the one-time login code to the backend logs (no email server).
# smtp    = email the code to the user (configure SMTP_* below).
EMAIL_MODE=console

# SMTP delivery — required when EMAIL_MODE=smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_NAME=ZQode Gateway
# Port 587 + STARTTLS (default), or port 465 + SSL (SMTP_STARTTLS=false, SMTP_SSL=true)
SMTP_STARTTLS=true
SMTP_SSL=false

# --- Runtime tuning ---
# uvicorn worker processes; a good starting point is the host's CPU core count.
UVICORN_WORKERS=4
# Host port nginx publishes the SPA on (map 443 + TLS at your LB/proxy).
HTTP_PORT=80
